apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Release.Name }}-janus
spec:
  replicas: 1
  selector:
    matchLabels:
      app: janus
  template:
    metadata:
      labels:
        app: janus
    spec:
      {{- if .Values.janus.hostNetwork }}
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      {{- end }}
      containers:
        - name: janus
          image: {{ .Values.janus.image }}
          # Pass the public IP to Janus so it can route WebRTC traffic
          {{- if .Values.janus.publicIp }}
          command: ["/usr/local/bin/janus"]
          args: ["--nat-1-1={{ .Values.janus.publicIp }}"]
          {{- end }}
          ports:
            - containerPort: {{ .Values.janus.ports.ws }}
            - containerPort: {{ .Values.janus.ports.http }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ .Release.Name }}-janus
spec:
  selector:
    app: janus
  ports:
    - name: ws
      protocol: TCP
      port: {{ .Values.janus.ports.ws }}
      targetPort: {{ .Values.janus.ports.ws }}
    - name: http
      protocol: TCP
      port: {{ .Values.janus.ports.http }}
      targetPort: {{ .Values.janus.ports.http }}